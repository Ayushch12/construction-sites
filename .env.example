# ============================================================
# RAMELEC — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For Vercel deployment: add these in Dashboard → Project → Settings → Environment Variables

# ── Option A: SMTP (Gmail, OVH, etc.) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application

# ── Destination email ─────────────────────────────────────────
# Where contact form emails will be sent
CONTACT_EMAIL=ramelec.ang@gmail.com

# ── Option B: Resend (alternative to SMTP) ───────────────────
# If using Resend, uncomment and fill this, and edit api/send-email.js
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
